APP_ENV=local
APP_NAME=Voucher Auto Transfer Tool
DATA_DIR=runtime
DATABASE_PATH=runtime/app.db
UPLOAD_DIR=runtime/uploads
EXPORT_DIR=runtime/exports
OCR_DPI=300
OCR_CONFIDENCE_THRESHOLD=0.75
PADDLEOCR_MAX_SIDE_LIMIT=5600
PADDLEOCR_LANG=japan
PADDLEOCR_USE_GPU=true
REMOTE_OCR_BASE_URL=
REMOTE_OCR_TIMEOUT_SECONDS=300
OLLAMA_BASE_URL=https://YOUR-TRYCLOUDFLARE-URL.trycloudflare.com
OLLAMA_MODEL=openai/gpt-oss-120b
OLLAMA_API_STYLE=openai
OLLAMA_API_KEY=EMPTY
OLLAMA_THINK=
OLLAMA_TIMEOUT_SECONDS=900
OLLAMA_HEADERS_JSON=
OLLAMA_GENERATE_OPTIONS_JSON=
